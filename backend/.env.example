# ─────────────────────────────────────────────────────────────────
# CareerMitra AI — Backend Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────

# ── IBM watsonx.ai (Granite) ──────────────────────────────────────
IBM_API_KEY=your_ibm_api_key_here
IBM_PROJECT_ID=your_watsonx_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=ibm/granite-13b-instruct-v2

# ── IBM Watson Speech to Text ─────────────────────────────────────
# Create a Speech to Text instance in IBM Cloud:
# https://cloud.ibm.com/catalog/services/speech-to-text
WATSON_STT_API_KEY=your_stt_api_key_here
WATSON_STT_URL=https://api.us-south.speech-to-text.watson.cloud.ibm.com

# ── IBM Watson Text to Speech ─────────────────────────────────────
# Create a Text to Speech instance in IBM Cloud:
# https://cloud.ibm.com/catalog/services/text-to-speech
WATSON_TTS_API_KEY=your_tts_api_key_here
WATSON_TTS_URL=https://api.us-south.text-to-speech.watson.cloud.ibm.com

# ── IBM Watson Language Translator ───────────────────────────────
# Create a Language Translator instance in IBM Cloud:
# https://cloud.ibm.com/catalog/services/language-translator
WATSON_LT_API_KEY=your_lt_api_key_here
WATSON_LT_URL=https://api.us-south.language-translator.watson.cloud.ibm.com

# ── Admin Dashboard ───────────────────────────────────────────────
# Optional — if set, GET /api/admin/stats requires ?key=<this value>
# Leave blank to allow unauthenticated access (dev only)
ADMIN_SECRET_KEY=

# ── Server ────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
